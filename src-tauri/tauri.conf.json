{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YourSound",
  "version": "1.0.0",
  "identifier": "com.creativekonsoles.yoursound",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "YourSound — CK-1",
        "width": 1280,
        "height": 840,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "resources": {
      "resources/BlackHole2ch.driver": "BlackHole2ch.driver",
      "resources/yoursound_routing": "yoursound_routing"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
